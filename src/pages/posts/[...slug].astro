---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter((post) => !post.data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<BaseLayout
  title={post.data.title}
  description={post.data.summary}
  ogImage={`/open-graph/${post.id}.png`}
  type="article"
  publishedTime={post.data.publishedAt}
>
  <article>
    <header class="title-block">
      <div class="head">
        <p class="eyebrow">Writing</p>
        <h1>{post.data.title}</h1>
        {post.data.summary && <p class="summary">{post.data.summary}</p>}
      </div>
      <div class="tb-grid">
        <div class="tb-cell">
          <span class="tb-label" aria-hidden="true">Author</span>
          <span>Alexander West</span>
        </div>
        <div class="tb-cell">
          <span class="tb-label" aria-hidden="true">Date</span>
          <FormattedDate date={post.data.publishedAt} />
        </div>
      </div>
    </header>
    <div class="prose">
      <Content />
    </div>
    <a class="back" href="/">&larr; Back to all posts</a>
  </article>
</BaseLayout>
