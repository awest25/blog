---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---
<BaseLayout>
  <section class="intro">
    <p class="eyebrow">Writing</p>
    <h1>Notes and essays</h1>
    <p class="statement">
      Homelab, infrastructure, and building things
      <span class="ctx">— written down so I don't have to learn them twice.</span>
    </p>
  </section>

  {posts.length > 0 ? (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a class="post-card" href={`/posts/${post.id}/`}>
            <span class="t">{post.data.title}</span>
            {post.data.summary && <span class="s">{post.data.summary}</span>}
            <span class="d"><FormattedDate date={post.data.publishedAt} /></span>
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="empty">No posts yet.</p>
  )}
</BaseLayout>
